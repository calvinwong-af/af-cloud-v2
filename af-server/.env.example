# af-server/.env.example
# Copy to .env.local for local development
# Never commit .env.local — it contains credentials

# ---- GCP ----
# Path to service account JSON key for local dev
# On Cloud Run this is handled by the attached service account (ADC)
GOOGLE_APPLICATION_CREDENTIALS=./cloud-accele-freight-key.json

GOOGLE_CLOUD_PROJECT=cloud-accele-freight

# ---- External APIs ----
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---- App ----
# Set to "false" to enable live writes in normalisation scripts
DRY_RUN=true
